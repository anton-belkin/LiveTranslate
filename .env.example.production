# Production environment — for NAS deployment
# Copy to .env on the NAS and fill in your production values.
# See docs/deploy-nas.md for full deployment guide.

# Tailscale
TS_AUTHKEY=...
TS_HOSTNAME=...

# OAuth2 Proxy — production OAuth client
OAUTH2_PROXY_CLIENT_ID=
OAUTH2_PROXY_CLIENT_SECRET=
OAUTH2_PROXY_COOKIE_DOMAINS=
OAUTH2_PROXY_COOKIE_SECRET=
OAUTH2_PROXY_REDIRECT_URL=

# Azure Speech (server-side STT + MT)
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=switzerlandnorth
AZURE_SPEECH_ENDPOINT=https://switzerlandnorth.api.cognitive.microsoft.com/
AZURE_SPEECH_AUTO_DETECT_LANGS=de-DE,en-US,ru-RU
AZURE_SPEECH_TRANSLATION_TARGETS=de,en,ru
AZURE_SPEECH_DIARIZATION=false
AZURE_SPEECH_SAMPLE_RATE_HZ=16000

# Groq translation
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=openai/gpt-oss-120b
GROQ_TARGET_LANGS=en,de,ru
GROQ_STATIC_CONTEXT="This is professional meeting. Please translate the text into the target languages."

# Optional: extra oauth2-proxy skip-auth routes
OAUTH2_PROXY_SKIP_AUTH_ROUTES_EXTRA=
